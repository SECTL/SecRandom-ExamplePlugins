<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AssemblyName>SecRandom.ExamplePlugin</AssemblyName>
        <SecRandomCoreDll Condition="'$(SecRandomCoreDll)' == ''">$(MSBuildProjectDirectory)\lib\SecRandom.Core.dll</SecRandomCoreDll>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Avalonia" Version="12.0.3" />
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.3" />
        <Reference Include="SecRandom.Core">
            <HintPath>$(SecRandomCoreDll)</HintPath>
            <Private>false</Private>
        </Reference>
    </ItemGroup>
</Project>
